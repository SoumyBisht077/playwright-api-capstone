{
  "name": "@soumbish/playwright-api-capstone",
  "version": "1.0.0",
  "description": "Day 7 Capstone — Playwright API Testing Suite",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:auth": "playwright test tests/api/auth.spec.ts",
    "test:ci": "playwright test --workers=1 --retries=0",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "ajv": "^8.16.0",
    "dotenv": "^16.4.5"
  }
}
